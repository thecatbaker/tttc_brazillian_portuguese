    "czech"
    {
        "Tokens"
        {
            "NEW_ACHIEVEMENT_1808_1_NAME"           "Nezastavitelný"
            "NEW_ACHIEVEMENT_1808_1_DESC"           "Přežijte tři kola po sobě bez smrti."
            "NEW_ACHIEVEMENT_1808_2_NAME"           "Pomsti mě!"
            "NEW_ACHIEVEMENT_1808_2_DESC"           "Zabijte nepřítele, který nedávno zabil vašeho přítele."
            "NEW_ACHIEVEMENT_1808_3_NAME"           "Trojitá dávka traumatu"
            "NEW_ACHIEVEMENT_1808_3_DESC"           "Najděte tři mrtvá těla po sobě, která jste sami nezabili."
            "NEW_ACHIEVEMENT_1808_4_NAME"           "Pouto osudu"
            "NEW_ACHIEVEMENT_1808_4_DESC"           "Zabijte svého vraha posledním výstřelem před smrtí."
            "NEW_ACHIEVEMENT_1808_5_NAME"           "Skaut"
            "NEW_ACHIEVEMENT_1808_5_DESC"           "Začněte a dokončete mapu, aniž by vaše Karma kdy klesla pod 960, a to i během kola."
            "NEW_ACHIEVEMENT_1808_6_NAME"           "Mort"
            "NEW_ACHIEVEMENT_1808_6_DESC"           "Staňte se kuřetem."
            "NEW_ACHIEVEMENT_1808_7_NAME"           "Přítel"
            "NEW_ACHIEVEMENT_1808_7_DESC"           "Označte přítele jako přítele pomocí herního rozhraní. Hurá!"
            "NEW_ACHIEVEMENT_1808_8_NAME"           "Vandalismus"
            "NEW_ACHIEVEMENT_1808_8_DESC"           "Nastříkejte sprej vedle mrtvého těla."
            "NEW_ACHIEVEMENT_1808_9_NAME"           "Cesta kolem světa"
            "NEW_ACHIEVEMENT_1808_9_DESC"           "Dokončete kolo na všech oficiálních mapách a alespoň na jedné neoficiální mapě."
            "NEW_ACHIEVEMENT_1808_10_NAME"          "Dokázali jste to!"
            "NEW_ACHIEVEMENT_1808_10_DESC"          "Poprvé si zahrajte TTT Classic."
            "NEW_ACHIEVEMENT_1808_11_NAME"          "Kuřecí Miku"
            "NEW_ACHIEVEMENT_1808_11_DESC"          "Objevte se jako kuřecí verze Hatsune Miku."
            "NEW_ACHIEVEMENT_1808_12_NAME"          "Jeden z nás"
            "NEW_ACHIEVEMENT_1808_12_DESC"          "Navštivte TTTC Discord."
            "NEW_ACHIEVEMENT_1808_13_NAME"          "Hej Crazydogu"
            "NEW_ACHIEVEMENT_1808_13_DESC"          "Zahrajte si TTT s Crazydogem."
            "NEW_ACHIEVEMENT_1808_14_NAME"          "Přísný kritik"
            "NEW_ACHIEVEMENT_1808_14_DESC"          "Zabijte autora aktuální mapy (musí být nepřítel)."
            "NEW_ACHIEVEMENT_1808_16_NAME"          "Prořídnutí stáda"
            "NEW_ACHIEVEMENT_1808_16_DESC"          "Nasbírejte celkem 10 000 zabití každé role: Zrádce, Nevinného a Detektiva."
            "NEW_ACHIEVEMENT_1808_17_NAME"          "Dokonalý vzor"
            "NEW_ACHIEVEMENT_1808_17_DESC"          "Dokončete deset kol po sobě s perfektní Karmou."
            "NEW_ACHIEVEMENT_1808_18_NAME"          "Velký vítěz"
            "NEW_ACHIEVEMENT_1808_18_DESC"          "Vyhrajte 100 kol."
            "NEW_ACHIEVEMENT_1808_19_NAME"          "Velký smolař"
            "NEW_ACHIEVEMENT_1808_19_DESC"          "Prohrajte 100 kol."
            "NEW_ACHIEVEMENT_1808_21_NAME"          "Plukovník"
            "NEW_ACHIEVEMENT_1808_21_DESC"          "Nasbírejte během hraní celkem 1 000 zabití kuřat."
            "NEW_ACHIEVEMENT_1808_22_NAME"          "Můj dobrý přítel Charles"
            "NEW_ACHIEVEMENT_1808_22_DESC"          "Použijte herní ping celkem 1 000krát."
            "NEW_ACHIEVEMENT_1808_23_NAME"          "(Otrávené zabručení)"
            "NEW_ACHIEVEMENT_1808_23_DESC"          "Staňte se naštvaným tátou."
            "NEW_ACHIEVEMENT_1808_24_NAME"          "Ragequit"
            "NEW_ACHIEVEMENT_1808_24_DESC"          "Odpojte se ze serveru ihned po zabití."
            "NEW_ACHIEVEMENT_1808_25_NAME"          "Pollo Loco"
            "NEW_ACHIEVEMENT_1808_25_DESC"          "Zabijte hráče při hraní za kuře."
            "NEW_ACHIEVEMENT_1808_26_NAME"          "Kvokni si!"
            "NEW_ACHIEVEMENT_1808_26_DESC"          "Jako kuře zabij deset hráčů."
            "NEW_ACHIEVEMENT_1808_27_NAME"          "Jen tak tak"
            "NEW_ACHIEVEMENT_1808_27_DESC"          "Úspěšně zneškodni nastraženou C4."
            "NEW_ACHIEVEMENT_1808_28_NAME"          "Šlohnuto!"
            "NEW_ACHIEVEMENT_1808_28_DESC"          "Získej poslední zabití Zrádce pomocí zbraně určené výhradně pro Zrádce."
            "NEW_ACHIEVEMENT_1808_29_NAME"          "Nad rámec povinností"
            "NEW_ACHIEVEMENT_1808_29_DESC"          "Jako Nevinný sám eliminuj tři nebo více Zrádců v jednom kole."
        }
    }
