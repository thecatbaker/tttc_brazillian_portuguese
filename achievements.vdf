    "brazilian"
    {
        "Tokens"
        {
            "NEW_ACHIEVEMENT_1808_1_NAME"           "Trem sem freios"
            "NEW_ACHIEVEMENT_1808_1_DESC"           "Sobreviva três rodadas consecutivas sem morrer."
            "NEW_ACHIEVEMENT_1808_2_NAME"           "Me vingue!"
            "NEW_ACHIEVEMENT_1808_2_DESC"           "Mate um inimigo que recentemente matou um amigo."
            "NEW_ACHIEVEMENT_1808_3_NAME"           "Trilogia Traumática"
            "NEW_ACHIEVEMENT_1808_3_DESC"           "Ache três corpos consecutivamente que você não matou."
            "NEW_ACHIEVEMENT_1808_4_NAME"           "Você vai junto comigo"
            "NEW_ACHIEVEMENT_1808_4_DESC"           "Mate seu assassino com um tiro de morte."
            "NEW_ACHIEVEMENT_1808_5_NAME"           "Escoteiro"
            "NEW_ACHIEVEMENT_1808_5_DESC"           "Começe e termine uma partida com seu karma NUNCA caindo para 0."
            "NEW_ACHIEVEMENT_1808_6_NAME"           "Mort"
            "NEW_ACHIEVEMENT_1808_6_DESC"           "Vire uma galinha."
            "NEW_ACHIEVEMENT_1808_7_NAME"           "Você é um amigo"
            "NEW_ACHIEVEMENT_1808_7_DESC"           "Marque um amigo como \"Amigo\" no placar. Eba!"
            "NEW_ACHIEVEMENT_1808_8_NAME"           "Vandalismo"
            "NEW_ACHIEVEMENT_1808_8_DESC"           "Use um spray ao lado de um corpo."
            "NEW_ACHIEVEMENT_1808_9_NAME"           "World Tour"
            "NEW_ACHIEVEMENT_1808_9_DESC"           "Complete uma rodada em todos os mapas oficiais e pelo menos um mapa não oficial."
            "NEW_ACHIEVEMENT_1808_10_NAME"          "Você conseguiu!"
            "NEW_ACHIEVEMENT_1808_10_DESC"          "Jogue TTT Classic pela a primeira vez."
            "NEW_ACHIEVEMENT_1808_11_NAME"          "Galinha Miku"
            "NEW_ACHIEVEMENT_1808_11_DESC"          "Apareça como uma galinha com a skin de Hatsune Miku."
            "NEW_ACHIEVEMENT_1808_12_NAME"          "Um de nós"
            "NEW_ACHIEVEMENT_1808_12_DESC"          "Visite o discord de TTT Classic no menu."
            "NEW_ACHIEVEMENT_1808_13_NAME"          "Oi Crazydog!"
            "NEW_ACHIEVEMENT_1808_13_DESC"          "Jogue TTTC com o Crazydog."
            "NEW_ACHIEVEMENT_1808_14_NAME"          "Crítica Destrutiva"
            "NEW_ACHIEVEMENT_1808_14_DESC"          "Mate o criador de um mapa (Com ele sendo um inimigo)"
            "NEW_ACHIEVEMENT_1808_16_NAME"          "Dividindo o rebanho"
            "NEW_ACHIEVEMENT_1808_16_DESC"          "Acumule 10.000 mortes em cada função: Traidor, Inocente, e Detetive."
            "NEW_ACHIEVEMENT_1808_17_NAME"          "Santo"
            "NEW_ACHIEVEMENT_1808_17_DESC"          "Termine 10 rodadas seguidas com Karma perfeito."
            "NEW_ACHIEVEMENT_1808_18_NAME"          "Grande Vencedor"
            "NEW_ACHIEVEMENT_1808_18_DESC"          "Vença 100 rodadas."
            "NEW_ACHIEVEMENT_1808_19_NAME"          "Grande PERDEDOR!"
            "NEW_ACHIEVEMENT_1808_19_DESC"          "Perca 100 rodadas."
            "NEW_ACHIEVEMENT_1808_21_NAME"          "O Coronel"
            "NEW_ACHIEVEMENT_1808_21_DESC"          "Mate 10.000 galinhas."
            "NEW_ACHIEVEMENT_1808_22_NAME"          "Meu amigão Charles"
            "NEW_ACHIEVEMENT_1808_22_DESC"          "Use a função de Ping 1.000 vezes."
            "NEW_ACHIEVEMENT_1808_23_NAME"          "(Terrorista Irritado)"
